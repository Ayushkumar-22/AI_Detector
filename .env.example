# =============================================
# HuggingFace Configuration
# =============================================
# Optional: your HuggingFace token (only needed for private models)
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN=your-huggingface-token-here

# =============================================
# Model Configuration
# =============================================
# Primary CLIP model for detection
CLIP_MODEL=openai/clip-vit-large-patch14

# Secondary model for ensemble (optional)
CLIP_MODEL_2=openai/clip-vit-base-patch32

# Use ensemble of two models for better accuracy
USE_ENSEMBLE=true

# =============================================
# Detection Settings
# =============================================
# Confidence threshold to classify as AI-generated (0.0 to 1.0)
# Higher = stricter (fewer false positives, more false negatives)
DETECTION_THRESHOLD=0.5

# =============================================
# App Settings
# =============================================
APP_TITLE=AI Image Detector
DEBUG_MODE=false

# =============================================
# Cache Settings
# =============================================
# Where to store downloaded models
MODEL_CACHE_DIR=./models/cache
